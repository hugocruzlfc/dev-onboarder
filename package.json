{
  "name": "dev-onboarder",
  "version": "1.0.0",
  "description": "CLI tool that analyzes a project and generates an onboarding guide for new developers",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "project-onboarder": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "onboarding",
    "documentation",
    "cli",
    "developer-experience",
    "project-analysis"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "ora": "^5.4.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
