{
  "name": "dev-onboarder",
  "version": "0.2.0",
  "description": "CLI tool that analyzes any Node.js/TypeScript project and generates an onboarding guide for new developers",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "dev-onboarder": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "onboarding",
    "documentation",
    "cli",
    "developer-experience",
    "project-analysis",
    "code-analysis",
    "mermaid",
    "architecture",
    "readme-generator",
    "developer-tools"
  ],
  "author": "Hugo Cruz <hugocruzlfc@gmail.com> (https://github.com/hugocruzlfc)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hugocruzlfc/dev-onboarder.git"
  },
  "homepage": "https://github.com/hugocruzlfc/dev-onboarder",
  "bugs": {
    "url": "https://github.com/hugocruzlfc/dev-onboarder/issues"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "ora": "^5.4.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
